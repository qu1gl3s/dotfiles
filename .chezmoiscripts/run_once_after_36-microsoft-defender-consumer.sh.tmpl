{{ if ne .chezmoi.os "darwin" -}}
{{ else if and (hasKey . "skipDefender") .skipDefender -}}
#!/bin/bash
echo "==> [36] Skipping Microsoft Defender install (disabled in chezmoi.toml)"
{{ else -}}
#!/bin/bash
set -euo pipefail
#
# Script: run_once_after_36-microsoft-defender-consumer.sh.tmpl
# Purpose: Install Microsoft Defender for Consumers from Microsoft's fwlink.
# Prerequisites: macOS, internet access, admin privileges.
# Env override: CHEZMOI_SKIP_DEFENDER=1

if [[ "${CHEZMOI_SKIP_DEFENDER:-0}" == "1" ]]; then
  echo "==> [36] Skipping Microsoft Defender install (CHEZMOI_SKIP_DEFENDER=1)"
  exit 0
fi

echo "==> [36] Microsoft Defender installer"

SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
# shellcheck source=scripts/lib.sh
source "${SOURCE_DIR}/scripts/lib.sh"

DEFENDER_URL="https://go.microsoft.com/fwlink/?linkid=2247001"

if is_defender_installed; then
  echo "Microsoft Defender already installed; skipping."
  exit 0
fi

tmp_dir="$(mktemp -d)"
download_path="${tmp_dir}/defender-installer"

cleanup() {
  rm -rf "${tmp_dir}"
}
trap cleanup EXIT

echo "Downloading Microsoft Defender installer..."
curl -fL --retry 3 --retry-delay 2 -o "${download_path}" "${DEFENDER_URL}"

if [[ ! -s "${download_path}" ]]; then
  echo "Downloaded installer is empty: ${download_path}" >&2
  exit 1
fi

file_type="$(file -b "${download_path}")"

install_pkg_file() {
  local pkg_input="$1"
  local pkg_for_install="${pkg_input}"

  # installer can reject valid pkg payloads when the filename lacks a .pkg suffix.
  if [[ "${pkg_for_install}" != *.pkg ]]; then
    pkg_for_install="${tmp_dir}/defender-installer.pkg"
    cp "${pkg_input}" "${pkg_for_install}"
  fi

  echo "Installing package: ${pkg_for_install}"
  sudo /usr/sbin/installer -pkg "${pkg_for_install}" -target /
}

if ! pkgutil --check-signature "${download_path}" >/dev/null 2>&1; then
  echo "Downloaded installer did not validate as a signed pkg." >&2
  echo "Detected file type: ${file_type}" >&2
  exit 1
fi

echo "Detected PKG installer; installing..."
install_pkg_file "${download_path}"

if ! is_defender_installed; then
  echo "Microsoft Defender app was not detected after installer run." >&2
  exit 1
fi

cat <<'POSTINSTALL'
Microsoft Defender app installation completed.

Manual post-install steps required by macOS:
1) Approve Microsoft system extensions and network extensions in System Settings.
2) Reboot after approvals.
POSTINSTALL
{{ end -}}
