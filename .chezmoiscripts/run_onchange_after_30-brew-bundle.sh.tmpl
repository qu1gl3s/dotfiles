{{ if ne .chezmoi.os "darwin" -}}
{{ else if and (hasKey . "skipBrew") .skipBrew -}}
#!/bin/bash
echo "==> [30] Skipping Homebrew bundle (disabled in chezmoi.toml)"
{{ else -}}
#!/bin/bash
set -euo pipefail
#
# Script: run_onchange_after_30-brew-bundle.sh.tmpl
# Purpose: Apply Homebrew package state when Brewfile inputs change.
# Prerequisites: macOS with Homebrew available in /opt/homebrew.
# Env overrides: CHEZMOI_SKIP_BREW=1, CHEZMOI_INSTALL_OPTIONAL=1
# Trigger hash (Brewfile): {{ include "Brewfile" | sha256sum }}
# Trigger hash (Brewfile.optional): {{ include "Brewfile.optional" | sha256sum }}

if [[ "${CHEZMOI_SKIP_BREW:-0}" == "1" ]]; then
  echo "==> [30] Skipping Homebrew bundle (CHEZMOI_SKIP_BREW=1)"
  exit 0
fi

echo "==> [30] Homebrew bundle"

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

if ! command -v brew >/dev/null 2>&1; then
  cat >&2 <<'EOF'
Homebrew not found. Prerequisites must be installed before brew bundle can run.
Bootstrap with:
  sh -c "$(curl -fsLS get.chezmoi.io/lb)" -- init --apply <github-user>
EOF
  exit 1
fi

SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"

echo "Installing Homebrew packages..."
brew bundle --file "${SOURCE_DIR}/Brewfile"

if [[ "{{ if hasKey . "installOptional" }}{{ .installOptional }}{{ else }}false{{ end }}" == "true" || "${CHEZMOI_INSTALL_OPTIONAL:-0}" == "1" ]]; then
  if [[ -f "${SOURCE_DIR}/Brewfile.optional" ]]; then
    echo "Installing optional Homebrew packages..."
    brew bundle --file "${SOURCE_DIR}/Brewfile.optional"
  fi
fi
{{ end -}}
