{{ if ne .chezmoi.os "darwin" -}}
{{ else if .skipBrew -}}
#!/bin/bash
echo "==> [32] Skipping 1Password SSH agent compatibility (disabled in chezmoi.toml)"
{{ else -}}
#!/bin/bash
set -euo pipefail
#
# Script: run_onchange_after_32-1password-ssh-agent-compat.sh.tmpl
# Purpose: Ensure modern 1Password SSH agent socket path exists for OpenSSH config.
# Prerequisites: macOS, 1Password app installed and SSH agent enabled.
# Env override: CHEZMOI_SKIP_BREW=1
# Trigger hash (socket state): {{ output "bash" "-lc" "modern=\"$HOME/.1password/agent.sock\"; legacy=\"$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock\"; if [ -S \"$modern\" ]; then echo modern-present; elif [ -S \"$legacy\" ]; then echo legacy-only; else echo missing; fi" | sha256sum }}

if [[ "${CHEZMOI_SKIP_BREW:-0}" == "1" ]]; then
  echo "==> [32] Skipping 1Password SSH agent compatibility (CHEZMOI_SKIP_BREW=1)"
  exit 0
fi

echo "==> [32] 1Password SSH agent compatibility"

MODERN_AGENT_SOCK="${HOME}/.1password/agent.sock"
LEGACY_AGENT_SOCK="${HOME}/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

if [[ -S "${MODERN_AGENT_SOCK}" ]]; then
  echo "1Password SSH agent socket is available at ${MODERN_AGENT_SOCK}."
  exit 0
fi

if [[ -S "${LEGACY_AGENT_SOCK}" ]]; then
  mkdir -p "${HOME}/.1password"
  ln -sfn "${LEGACY_AGENT_SOCK}" "${MODERN_AGENT_SOCK}"

  if [[ -S "${MODERN_AGENT_SOCK}" ]]; then
    echo "Linked ${MODERN_AGENT_SOCK} -> ${LEGACY_AGENT_SOCK}."
    exit 0
  fi
fi

echo "WARN: 1Password SSH agent socket not found at ${MODERN_AGENT_SOCK} or legacy location."
echo "WARN: Open 1Password and enable SSH agent, then rerun chezmoi apply."
{{ end -}}
