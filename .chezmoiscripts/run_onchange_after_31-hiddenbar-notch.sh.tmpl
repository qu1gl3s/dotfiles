{{ if ne .chezmoi.os "darwin" -}}
{{ else if and (hasKey . "skipBrew") .skipBrew -}}
#!/bin/bash
echo "==> [31] Skipping HiddenBar notch check (disabled in chezmoi.toml)"
{{ else -}}
#!/bin/bash
set -euo pipefail
#
# Script: run_onchange_after_31-hiddenbar-notch.sh.tmpl
# Purpose: Install HiddenBar only on Apple Silicon MacBooks with a notched display era profile.
# Prerequisites: macOS, Homebrew available in /opt/homebrew.
# Env override: CHEZMOI_SKIP_BREW=1

if [[ "${CHEZMOI_SKIP_BREW:-0}" == "1" ]]; then
  echo "==> [31] Skipping HiddenBar notch check (CHEZMOI_SKIP_BREW=1)"
  exit 0
fi

echo "==> [31] HiddenBar notch check"

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew is required for HiddenBar installation but was not found." >&2
  exit 1
fi

echo "Querying hardware profile..."
hw_data="$(system_profiler SPHardwareDataType 2>/dev/null)"
model_name="$(awk -F': ' '/Model Name/ {print $2; exit}' <<< "${hw_data}")"
chip_name="$(awk -F': ' '/Chip/ {print $2; exit}' <<< "${hw_data}")"

has_notch=0
case "${model_name}" in
  "MacBook Air")
    if [[ "${chip_name}" != "Apple M1" ]]; then
      has_notch=1
    fi
    ;;
  "MacBook Pro")
    if [[ "${chip_name}" != "Apple M1" && "${chip_name}" != "Apple M2" ]]; then
      has_notch=1
    fi
    ;;
  *)
    has_notch=0
    ;;
esac

if [[ "${has_notch}" -ne 1 ]]; then
  echo "Skipping HiddenBar install; notch not detected for model '${model_name:-unknown}' (chip '${chip_name:-unknown}')."
  exit 0
fi

if brew list --cask hiddenbar >/dev/null 2>&1; then
  echo "HiddenBar already installed."
  exit 0
fi

echo "Installing HiddenBar (notch-capable model detected)."
brew install --cask hiddenbar
{{ end -}}
