{{ if ne .chezmoi.os "darwin" -}}
{{ else if or .skipBrew .skipDisplayScaling -}}
#!/bin/bash
echo "==> [42] Skipping display scaling (disabled in chezmoi.toml)"
{{ else -}}
#!/bin/bash
set -euo pipefail
#
# Script: run_onchange_after_42-display-more-space.sh.tmpl
# Purpose: Enforce built-in display to "More Space" by selecting the highest scaled mode.
# Prerequisites: macOS with displayplacer available.
# Env overrides: CHEZMOI_SKIP_BREW=1, CHEZMOI_SKIP_DISPLAY_SCALING=1
# Trigger hash (display convergence state + display fingerprint): {{ output "bash" "-lc" "state_file=\"$HOME/.local/state/chezmoi/display-scaling-state\"; if [ -f \"$state_file\" ]; then state=$(cat \"$state_file\"); else state=unset; fi; if command -v displayplacer >/dev/null 2>&1; then if display_out=$(displayplacer list 2>/dev/null); then fingerprint=\"$display_out\"; else fingerprint=displayplacer-list-error; fi; else fingerprint=displayplacer-missing; fi; printf \"%s|%s\" \"$state\" \"$fingerprint\"" | sha256sum }}

if [[ "${CHEZMOI_SKIP_BREW:-0}" == "1" ]]; then
  echo "==> [42] Skipping display scaling (CHEZMOI_SKIP_BREW=1)"
  exit 0
fi

if [[ "${CHEZMOI_SKIP_DISPLAY_SCALING:-0}" == "1" ]]; then
  echo "==> [42] Skipping display scaling (CHEZMOI_SKIP_DISPLAY_SCALING=1)"
  exit 0
fi

echo "==> [42] Display scaling (More Space)"

STATE_DIR="${HOME}/.local/state/chezmoi"
DISPLAY_STATE_FILE="${STATE_DIR}/display-scaling-state"
DISPLAY_FINGERPRINT=""
PREVIOUS_DISPLAY_STATE=""

compute_display_fingerprint() {
  printf '%s' "${display_list_output}" | shasum -a 256 | awk '{print $1}'
}

load_previous_state() {
  if [[ -f "${DISPLAY_STATE_FILE}" ]]; then
    PREVIOUS_DISPLAY_STATE="$(cat "${DISPLAY_STATE_FILE}")"
  else
    PREVIOUS_DISPLAY_STATE=""
  fi
}

mark_pending() {
  local reason="${1:-generic}"
  mkdir -p "${STATE_DIR}"
  printf 'pending:%s:%s\n' "${reason}" "${DISPLAY_FINGERPRINT}" > "${DISPLAY_STATE_FILE}"
}

mark_aligned() {
  mkdir -p "${STATE_DIR}"
  printf 'aligned:%s\n' "${DISPLAY_FINGERPRINT}" > "${DISPLAY_STATE_FILE}"
}

defer_with_warning() {
  local message="$1"
  local reason="${2:-generic}"
  echo "WARN: ${message}"
  mark_pending "${reason}"
  exit 0
}

display_subsystem_reports_builtin_panel() {
  ioreg -lw0 -r -c AppleCLCD2 >/dev/null 2>&1 || ioreg -lw0 -r -c AppleCLCD >/dev/null 2>&1
}

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

if ! command -v displayplacer >/dev/null 2>&1; then
  defer_with_warning "displayplacer not found; deferring display scaling until Homebrew tools are installed." "missing-displayplacer"
fi

display_list_output="$(displayplacer list 2>/dev/null || true)"
if [[ -z "${display_list_output}" ]]; then
  defer_with_warning "displayplacer returned no output; deferring display scaling for this apply." "empty-display-list"
fi

DISPLAY_FINGERPRINT="$(compute_display_fingerprint)"
load_previous_state

builtin_count=0
current_id=""
current_builtin=0
current_best_area=-1
current_best_res=""
current_resolution=""
current_scaling=""

builtin_id=""
builtin_target_res=""
builtin_current_res=""
builtin_current_scaling=""

finalize_display() {
  if [[ "${current_builtin}" -eq 1 ]]; then
    ((builtin_count += 1))
    builtin_id="${current_id}"
    builtin_target_res="${current_best_res}"
    builtin_current_res="${current_resolution}"
    builtin_current_scaling="${current_scaling}"
  fi
}

while IFS= read -r line; do
  if [[ "${line}" =~ ^[[:space:]]*Persistent[[:space:]]screen[[:space:]]id:[[:space:]]*(.+)$ ]]; then
    if [[ -n "${current_id}" ]]; then
      finalize_display
    fi
    current_id="${BASH_REMATCH[1]}"
    current_builtin=0
    current_best_area=-1
    current_best_res=""
    current_resolution=""
    current_scaling=""
    continue
  fi

  [[ -z "${current_id}" ]] && continue

  if [[ "${line}" =~ ^[[:space:]]*Type:[[:space:]]*(.+)$ ]]; then
    display_type="${BASH_REMATCH[1]}"
    if [[ "${display_type}" =~ [Bb]uilt-?[Ii]n|[Ii]nternal|[Mm]ac[Bb]ook ]]; then
      current_builtin=1
    fi
    continue
  fi

  if [[ "${line}" =~ ^[[:space:]]*Resolution:[[:space:]]*([0-9]+x[0-9]+) ]]; then
    current_resolution="${BASH_REMATCH[1]}"
    continue
  fi

  if [[ "${line}" =~ ^[[:space:]]*Scaling:[[:space:]]*(on|off) ]]; then
    current_scaling="${BASH_REMATCH[1]}"
    continue
  fi

  if [[ "${current_builtin}" -eq 1 && "${line}" =~ res:([0-9]+)x([0-9]+).*scaling:on ]]; then
    mode_w="${BASH_REMATCH[1]}"
    mode_h="${BASH_REMATCH[2]}"
    mode_area=$((mode_w * mode_h))
    if [[ "${mode_area}" -gt "${current_best_area}" ]]; then
      current_best_area="${mode_area}"
      current_best_res="${mode_w}x${mode_h}"
    fi
  fi
done <<< "${display_list_output}"

if [[ -n "${current_id}" ]]; then
  finalize_display
fi

if [[ "${builtin_count}" -eq 0 ]]; then
  if display_subsystem_reports_builtin_panel; then
    defer_with_warning "displayplacer did not enumerate the built-in panel, but lower-level display services did. Deferring display scaling on this Mac until tooling catches up." "builtin-panel-not-enumerated"
  fi
  defer_with_warning "Built-in display not detected (clamshell/external-only). Open built-in display and rerun chezmoi apply." "builtin-panel-unavailable"
fi

if [[ "${builtin_count}" -gt 1 ]]; then
  defer_with_warning "Multiple built-in displays detected; deferring display scaling until display topology is unambiguous." "multiple-builtins"
fi

if [[ -z "${builtin_target_res}" ]]; then
  defer_with_warning "No scaling:on modes found for built-in display; deferring display scaling." "no-scaled-modes"
fi

if [[ "${builtin_current_scaling}" == "on" && "${builtin_current_res}" == "${builtin_target_res}" ]]; then
  mark_aligned
  echo "Built-in display already set to More Space (${builtin_target_res})."
  exit 0
fi

if [[ "${PREVIOUS_DISPLAY_STATE}" == "pending:apply-failed-${builtin_target_res}:${DISPLAY_FINGERPRINT}" ]]; then
  echo "Built-in display More Space apply previously failed for unchanged display state (${builtin_target_res}); skipping retry."
  exit 0
fi

if ! displayplacer "id:${builtin_id} res:${builtin_target_res} scaling:on" >/dev/null 2>&1; then
  defer_with_warning "displayplacer could not apply ${builtin_target_res}; unlock Displays settings/reconnect displays and rerun chezmoi apply." "apply-failed-${builtin_target_res}"
fi

mark_aligned
echo "Applied built-in display More Space mode: ${builtin_target_res}"
{{ end -}}
