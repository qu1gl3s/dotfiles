{{ if ne .chezmoi.os "darwin" -}}
{{ else if and (hasKey . "skipMacosDefaults") .skipMacosDefaults -}}
#!/bin/bash
echo "==> [40] Skipping macOS defaults (disabled in chezmoi.toml)"
{{ else -}}
#!/bin/bash
set -euo pipefail
#
# Script: run_onchange_after_40-macos-defaults.sh.tmpl
# Purpose: Apply allowlisted macOS system settings.
# Prerequisites: macOS, settings baseline file present in source dir.
# Env override: CHEZMOI_SKIP_MACOS_DEFAULTS=1
# Trigger hash (macos/settings-baseline.sh): {{ include "macos/settings-baseline.sh" | sha256sum }}
# Trigger hash (Dock visibility state): {{ output "bash" "-lc" "for key in autohide show-recents magnification largesize minimize-to-application; do if value=$(defaults read com.apple.dock \"$key\" 2>/dev/null); then printf '%s=%s\\n' \"$key\" \"$value\"; else printf '%s=__unset__\\n' \"$key\"; fi; done" | sha256sum }}

if [[ "${CHEZMOI_SKIP_MACOS_DEFAULTS:-0}" == "1" ]]; then
  echo "==> [40] Skipping macOS defaults (CHEZMOI_SKIP_MACOS_DEFAULTS=1)"
  exit 0
fi

echo "==> [40] macOS defaults"

SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
BASELINE_FILE="${SOURCE_DIR}/macos/settings-baseline.sh"

if [[ ! -f "${BASELINE_FILE}" ]]; then
  echo "Missing baseline file: ${BASELINE_FILE}" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "${BASELINE_FILE}"

if ! declare -F macos_settings_entries >/dev/null 2>&1; then
  echo "macos_settings_entries function not found in ${BASELINE_FILE}" >&2
  exit 1
fi

normalize_bool() {
  case "${1}" in
    1|true|TRUE|yes|YES|on|ON) echo 1 ;;
    0|false|FALSE|no|NO|off|OFF) echo 0 ;;
    *) echo "${1}" ;;
  esac
}

values_equal() {
  local type="$1"
  local current="$2"
  local desired="$3"

  case "${type}" in
    bool)
      [[ "$(normalize_bool "${current}")" == "$(normalize_bool "${desired}")" ]]
      ;;
    int)
      [[ "${current}" == "${desired}" ]]
      ;;
    float)
      awk -v a="${current}" -v b="${desired}" 'BEGIN { d=a-b; if (d<0) d=-d; exit(d<0.000001?0:1) }'
      ;;
    string)
      [[ "${current}" == "${desired}" ]]
      ;;
    *)
      return 1
      ;;
  esac
}

ensure_finder_toolbar_layout() {
  local plist_path="${HOME}/Library/Preferences/com.apple.finder.plist"
  local update_status=0
  local desired_items=""
  local desired_default_items=""

  if ! declare -F finder_toolbar_item_identifiers >/dev/null 2>&1; then
    echo "finder_toolbar_item_identifiers function not found in ${BASELINE_FILE}" >&2
    return 1
  fi

  if ! declare -F finder_toolbar_default_item_identifiers >/dev/null 2>&1; then
    echo "finder_toolbar_default_item_identifiers function not found in ${BASELINE_FILE}" >&2
    return 1
  fi

  desired_items="$(finder_toolbar_item_identifiers)"
  desired_default_items="$(finder_toolbar_default_item_identifiers)"

  if FINDER_TOOLBAR_ITEMS="${desired_items}" \
    FINDER_TOOLBAR_DEFAULT_ITEMS="${desired_default_items}" \
    python3 - "${plist_path}" <<'PY'
import plistlib
import os
import sys
from pathlib import Path

plist_path = Path(sys.argv[1])

desired_items = os.environ["FINDER_TOOLBAR_ITEMS"].splitlines()
desired_default_items = os.environ["FINDER_TOOLBAR_DEFAULT_ITEMS"].splitlines()
desired_toolbar = {
    "TB Default Item Identifiers": desired_default_items,
    "TB Display Mode": 2,
    "TB Icon Size Mode": 1,
    "TB Is Shown": True,
    "TB Item Identifiers": desired_items,
    "TB Size Mode": 1,
}

data = {}
if plist_path.exists():
    with plist_path.open("rb") as fh:
        data = plistlib.load(fh)

if data.get("NSToolbar Configuration Browser") == desired_toolbar:
    raise SystemExit(0)

data["NSToolbar Configuration Browser"] = desired_toolbar
with plist_path.open("wb") as fh:
    plistlib.dump(data, fh, fmt=plistlib.FMT_BINARY, sort_keys=False)

raise SystemExit(10)
PY
  then
    update_status=0
  else
    update_status=$?
  fi

  case "${update_status}" in
    0)
      return 0
      ;;
    10)
      echo "Applied Finder toolbar layout (Trash before Search)"
      restart_finder=1
      return 0
      ;;
    *)
      echo "Unable to update Finder toolbar layout" >&2
      return 1
      ;;
  esac
}

write_setting() {
  local domain="$1"
  local key="$2"
  local type="$3"
  local value="$4"
  local normalized_bool=""

  case "${type}" in
    bool)
      normalized_bool="$(normalize_bool "${value}")"
      case "${normalized_bool}" in
        1) defaults write "${domain}" "${key}" -bool true ;;
        0) defaults write "${domain}" "${key}" -bool false ;;
        *)
          echo "Unsupported bool value '${value}' for ${domain} ${key}" >&2
          return 1
          ;;
      esac
      ;;
    int) defaults write "${domain}" "${key}" -int "${value}" ;;
    float) defaults write "${domain}" "${key}" -float "${value}" ;;
    string) defaults write "${domain}" "${key}" -string "${value}" ;;
    *)
      echo "Unsupported type '${type}' for ${domain} ${key}" >&2
      return 1
      ;;
  esac
}

resolve_dynamic_value() {
  local domain="$1"
  local key="$2"
  local type="$3"
  local value="$4"

  if [[ "${domain}" == "com.apple.finder" && "${key}" == "NewWindowTargetPath" && "${type}" == "string" && "${value}" == "__HOME_URI__" ]]; then
    printf 'file://%s/' "${HOME}"
    return 0
  fi

  printf '%s' "${value}"
}

restart_dock=0
restart_finder=0
restart_systemuiserver=0

while read -r domain key type value; do
  [[ -z "${domain}" || "${domain:0:1}" == "#" ]] && continue

  current=""
  has_current=0
  if current="$(defaults read "${domain}" "${key}" 2>/dev/null)"; then
    has_current=1
  fi

  desired_value="$(resolve_dynamic_value "${domain}" "${key}" "${type}" "${value}")"

  if [[ "${has_current}" -eq 1 ]] && values_equal "${type}" "${current}" "${desired_value}"; then
    continue
  fi

  write_setting "${domain}" "${key}" "${type}" "${desired_value}"
  echo "Applied ${domain} ${key}=${desired_value}"

  case "${domain}" in
    com.apple.dock) restart_dock=1 ;;
    com.apple.finder) restart_finder=1 ;;
    com.apple.desktopservices) restart_finder=1 ;;
    com.apple.screencapture) restart_systemuiserver=1 ;;
    com.apple.WindowManager) restart_dock=1 ;;
  esac
done < <(macos_settings_entries)

ensure_finder_toolbar_layout

if [[ "${restart_dock}" -eq 1 ]]; then
  killall Dock >/dev/null 2>&1 || true
fi

if [[ "${restart_finder}" -eq 1 ]]; then
  killall Finder >/dev/null 2>&1 || true
fi

if [[ "${restart_systemuiserver}" -eq 1 ]]; then
  killall SystemUIServer >/dev/null 2>&1 || true
fi
{{ end -}}
