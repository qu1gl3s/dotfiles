{{ if ne .chezmoi.os "darwin" -}}
{{ else if or (and (hasKey . "skipBrew") .skipBrew) (and (hasKey . "skipMas") .skipMas) -}}
#!/bin/bash
echo "==> [34] Skipping Mac App Store installs (disabled in chezmoi.toml)"
{{ else -}}
#!/bin/bash
set -euo pipefail
#
# Script: run_onchange_after_34-mas-apps.sh.tmpl
# Purpose: Install required Mac App Store apps with mas.
# Prerequisites: macOS, Homebrew mas formula installed, App Store login.
# Env overrides: CHEZMOI_SKIP_BREW=1, CHEZMOI_SKIP_MAS=1, CHEZMOI_INSTALL_OPTIONAL=1
# Trigger hash (mas/apps.txt): {{ include "mas/apps.txt" | sha256sum }}
# Trigger hash (mas/optional-apps.txt): {{ include "mas/optional-apps.txt" | sha256sum }}
# Trigger hash (mas convergence state): {{ output "bash" "-lc" "state_file=\"$HOME/.local/state/chezmoi/mas-convergence-state\"; state=\"unset\"; if [ -f \"$state_file\" ]; then state=\"$(cat \"$state_file\")\"; fi; case \"$state\" in retry-pending*) printf 'retry-%s\n' \"$(date +%s)\" ;; blocked-auth) if command -v mas >/dev/null 2>&1 && env MAS_NO_AUTO_INDEX=1 mas account >/dev/null 2>&1; then echo auth-restored; else echo blocked-auth; fi ;; *) echo \"$state\" ;; esac" | sha256sum }}

if [[ "${CHEZMOI_SKIP_BREW:-0}" == "1" ]]; then
  echo "==> [34] Skipping Mac App Store installs (CHEZMOI_SKIP_BREW=1)"
  exit 0
fi

if [[ "${CHEZMOI_SKIP_MAS:-0}" == "1" ]]; then
  echo "==> [34] Skipping Mac App Store installs (CHEZMOI_SKIP_MAS=1)"
  exit 0
fi

echo "==> [34] Mac App Store installs"

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

if ! command -v mas >/dev/null 2>&1; then
  cat >&2 <<'EOF'
mas is required for Mac App Store app installs but was not found.
Install prerequisites with:
  brew install mas
EOF
  exit 1
fi

SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
MAS_APPS_FILE="${SOURCE_DIR}/mas/apps.txt"
MAS_OPTIONAL_APPS_FILE="${SOURCE_DIR}/mas/optional-apps.txt"
STATE_DIR="${HOME}/.local/state/chezmoi"
MAS_STATE_FILE="${STATE_DIR}/mas-convergence-state"

if [[ ! -f "${MAS_APPS_FILE}" ]]; then
  echo "Mac App Store app list not found: ${MAS_APPS_FILE}" >&2
  exit 1
fi

install_optional="{{ if hasKey . "installOptional" }}{{ .installOptional }}{{ else }}false{{ end }}"
if [[ "${install_optional}" == "true" || "${CHEZMOI_INSTALL_OPTIONAL:-0}" == "1" ]]; then
  install_optional="1"
fi

if [[ "${install_optional}" == "1" && ! -f "${MAS_OPTIONAL_APPS_FILE}" ]]; then
  echo "Optional Mac App Store app list not found: ${MAS_OPTIONAL_APPS_FILE}" >&2
  exit 1
fi

export MAS_NO_AUTO_INDEX=1

mark_pending() {
  mkdir -p "${STATE_DIR}"
  printf 'retry-pending-%s\n' "$(date +%s)" > "${MAS_STATE_FILE}"
}

mark_blocked_auth() {
  mkdir -p "${STATE_DIR}"
  printf 'blocked-auth\n' > "${MAS_STATE_FILE}"
}

mark_aligned() {
  mkdir -p "${STATE_DIR}"
  printf 'aligned\n' > "${MAS_STATE_FILE}"
}

is_auth_error() {
  local output="$1"
  grep -Eqi 'sign in|not signed|no account|account.*required|authentication|authenticate|login required' <<<"${output}"
}

run_with_timeout() {
  local timeout_seconds="$1"
  shift
  local tmp_output=""
  local pid=""
  local elapsed=0
  local status=0

  tmp_output="$(mktemp)"
  "$@" >"${tmp_output}" 2>&1 &
  pid=$!

  while kill -0 "${pid}" 2>/dev/null; do
    if [[ "${elapsed}" -ge "${timeout_seconds}" ]]; then
      kill "${pid}" 2>/dev/null || true
      wait "${pid}" 2>/dev/null || true
      cat "${tmp_output}"
      rm -f "${tmp_output}"
      return 124
    fi
    sleep 1
    ((elapsed += 1))
  done

  wait "${pid}" || status=$?
  cat "${tmp_output}"
  rm -f "${tmp_output}"
  return "${status}"
}

defer_for_auth() {
  local reason="$1"
  echo "WARN: ${reason}"
  echo "WARN: Deferring Mac App Store installs until auth/session is available. Rerun: chezmoi apply"
  mark_blocked_auth
  exit 0
}

mas_account_available() {
  local account_output=""
  local account_status=0

  account_output="$(run_with_timeout 10 env MAS_NO_AUTO_INDEX=1 mas account)" || account_status=$?
  [[ "${account_status}" -eq 0 ]]
}

mark_retry_state_for_session_issue() {
  if mas_account_available; then
    mark_pending
  else
    mark_blocked_auth
  fi
}

echo "Querying Mac App Store..."
mas_list_output=""
mas_list_status=0
mas_list_output="$(run_with_timeout 20 env MAS_NO_AUTO_INDEX=1 mas list)" || mas_list_status=$?

if [[ "${mas_list_status}" -eq 124 ]]; then
  echo "WARN: mas list timed out (likely App Store auth/session unavailable)."
  echo "WARN: Deferring Mac App Store installs until auth/session is available. Rerun: chezmoi apply"
  mark_retry_state_for_session_issue
  exit 0
elif [[ "${mas_list_status}" -ne 0 ]]; then
  if is_auth_error "${mas_list_output}"; then
    defer_for_auth "App Store authentication required for mas installs."
  fi
  echo "${mas_list_output}" >&2
  exit 1
fi

installed_ids="$(awk '{print $1}' <<<"${mas_list_output}")"

install_apps_from_file() {
  local apps_file="$1"
  local list_label="$2"
  local install_output=""
  local install_status=0

  while IFS='|' read -r app_id app_name; do
    [[ -z "${app_id}" || "${app_id:0:1}" == "#" ]] && continue

    if [[ -z "${app_name}" || ! "${app_id}" =~ ^[0-9]+$ ]]; then
      echo "Malformed MAS entry in ${apps_file}: ${app_id}|${app_name}" >&2
      return 1
    fi

    if grep -qx "${app_id}" <<<"${installed_ids}"; then
      echo "Using ${app_name} (${app_id})"
      continue
    fi

    echo "Installing ${list_label} app ${app_name} (${app_id}) from Mac App Store..."
    install_status=0
    install_output="$(run_with_timeout 60 mas install "${app_id}")" || install_status=$?
    if [[ "${install_status}" -eq 124 ]]; then
      echo "WARN: mas install timed out for ${app_name} (${app_id}); deferring remaining MAS installs."
      mark_retry_state_for_session_issue
      return 10
    fi

    if [[ "${install_status}" -ne 0 ]]; then
      echo "${install_output}" >&2
      if is_auth_error "${install_output}"; then
        echo "WARN: App Store authentication/session unavailable while installing ${app_name} (${app_id}); deferring remaining MAS installs."
        mark_retry_state_for_session_issue
        return 10
      fi
      return 1
    fi
    echo "${install_output}"
  done < "${apps_file}"

  return 0
}

if ! install_apps_from_file "${MAS_APPS_FILE}" "required"; then
  install_result=$?
  if [[ "${install_result}" -eq 10 ]]; then
    exit 0
  fi
  exit "${install_result}"
fi

if [[ "${install_optional}" == "1" ]]; then
  if ! install_apps_from_file "${MAS_OPTIONAL_APPS_FILE}" "optional"; then
    install_result=$?
    if [[ "${install_result}" -eq 10 ]]; then
      exit 0
    fi
    exit "${install_result}"
  fi
fi

mark_aligned
{{ end -}}
